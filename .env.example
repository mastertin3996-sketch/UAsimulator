# PostgreSQL connection (Neon recommended for Vercel)
# Get from: https://neon.tech  → New project → Connection string
DATABASE_URL="postgresql://user:password@host/uaeconomy?sslmode=require"

# Game tick interval for local dev (ms). Vercel uses Cron instead.
TICK_INTERVAL_MS=3600000

# Allowed frontend origin for CORS (Vercel frontend URL or localhost)
CORS_ORIGIN="http://localhost:5173"

# Protects the /cron/tick endpoint from unauthorized calls
# Generate: openssl rand -hex 32
CRON_SECRET="replace-with-random-secret"

# Node environment
NODE_ENV="development"
