generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum Profession {
  ACCOUNTANT
  MANAGER
  OPERATOR
  ENGINEER
  AGRONOMIST
  LOADER
  DRIVER
  SECURITY_GUARD
  SECURITY_OFFICER  // керівник служби безпеки; управляє SecuritySystem підприємства
  CLEANER
  SALES_REP
  IT_SPECIALIST
  LAWYER
  HR_SPECIALIST
  TECHNICIAN
  QUALITY_CONTROLLER
  RESEARCHER       // RD_LABORATORY: generates 5 RP/tick
  DATA_SCIENTIST   // RD_LABORATORY: generates 10 RP/tick
}

enum EnterpriseType {
  OFFICE           // адміністративний офіс — передумова для операцій у місті
  AGRO_FARM        // сільськогосподарське підприємство
  TEXTILE_FACTORY  // текстильне виробництво
  FOOD_PROCESSING  // харчова переробка (млин, олійня, молокозавод тощо)
  RETAIL_STORE     // роздрібна торгівля
  WAREHOUSE        // склад
  LOGISTICS_HUB    // логістичний термінал
  RD_LABORATORY    // науково-дослідна лабораторія — генерує очки досліджень (RP)
}

enum LandStatus {
  AVAILABLE // на ринку, ніким не придбана
  OWNED     // куплена гравцем
  LEASED    // орендована гравцем
}

enum EquipmentStatus {
  NEW          // wearAndTear < 0.10
  OPERATIONAL  // 0.10 ≤ wearAndTear < 0.80
  WORN         // 0.80 ≤ wearAndTear < 1.00  — продуктивність −50%
  BROKEN       // wearAndTear ≥ 1.00 або раптовий збій — продуктивність = 0
}

enum MarketOrderType {
  SELL
  BUY
}

enum MarketOrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  EXPIRED
}

enum ProductCategory {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOOD
  EQUIPMENT_ITEM
}

enum ConstructionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TransactionType {
  INITIAL_DEPOSIT
  LAND_PURCHASE
  LAND_LEASE_PAYMENT
  CONSTRUCTION_COST
  EQUIPMENT_PURCHASE
  ENERGY_BILL
  SALARY_PAYMENT
  TAX_PAYMENT
  MARKET_SALE
  MARKET_PURCHASE
  MAINTENANCE_COST
  NPC_SALE
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  FREIGHT_PAYMENT
  BANKRUPTCY_LIQUIDATION
  LOAN_INTEREST_PAYMENT
  REGULATORY_FINE
  LICENSE_FEE
  MACRO_EVENT_CHARGE
  MACRO_EVENT_BONUS
  RD_INVESTMENT      // Витрати на R&D-лабораторію (з/п дослідників, обладнання)
  AUTO_PROCUREMENT   // Автоматична B2B-закупівля за AutoContract
  STATE_SUBSIDY      // Субсидія / cashback від державної програми підтримки
  FX_EXCHANGE_BUY    // Купівля USD за UAH (міжбанк + 0.5% спред)
  FX_EXCHANGE_SELL   // Продаж USD за UAH (міжбанк − 0.5% спред)
  CUSTOMS_DUTY       // Ввізне мито 10% (→ StateBudget)
  CUSTOMS_VAT        // ПДВ при імпорті 20% (→ StateBudget)
  CUSTOMS_STORAGE_FEE // Складська плата при замороженні вантажу (500 UAH/тік)
  EXPORT_SALE        // Виручка від експорту (USD, зараховується після митниці)
  IMPORT_PURCHASE      // Оплата імпорту міжнародному постачальнику (USD)
  GREEN_ENERGY_INSTALL     // CAPEX на встановлення СЕС + акумуляторів
  DIESEL_FUEL_COST         // Витрати на дизельне паливо при резервному живленні
  SECURITY_MAINTENANCE     // Щотікові витрати на утримання SecuritySystem
  PATENT_REGISTRATION_FEE  // Держмито за реєстрацію патенту
  COURT_PENALTY_DEBIT      // Судовий штраф списаний з відповідача
  COURT_PENALTY_CREDIT     // Судовий штраф зарахований позивачу
  HOSTILE_ASSET_FREEZE_FEE // Судові витрати при накладанні арешту на активи
  MA_ACQUISITION_COST      // CAPEX на придбання підприємства / компанії (M&A)
  MA_SALE_REVENUE          // Виручка від продажу підприємства / компанії (M&A)
  DEPOSIT_OPEN             // Кошти заблоковано у депозит (дебет з рахунку)
  DEPOSIT_MATURITY         // Повернення депозиту разом із нарахованими відсотками
  REVENUE_INTEREST         // Відсотковий дохід за депозитом (частина DEPOSIT_MATURITY)
  OVERDRAFT_DRAWDOWN       // Автоматичне покриття дефіциту балансу через овердрафт
  OVERDRAFT_INTEREST       // Нарахування відсотків на залишок овердрафту (36% р./р.)
  IPO_PROCEEDS             // Надходження засновнику від продажу акцій публічного float
  STOCK_BUY                // Купівля акцій на вторинному ринку (дебет покупця)
  STOCK_SELL               // Продаж акцій на вторинному ринку (кредит продавця)
  DIVIDEND_PAYMENT         // Засновник виплачує дивіденди з власного балансу
  GM_ADJUSTMENT            // Ручне коригування балансу адміністратором гри
}

enum DepositCurrency {
  UAH
  USD
}

enum StockOrderType {
  BUY
  SELL
}

enum StockOrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum CustomsType {
  IMPORT
  EXPORT
}

enum MaDealStatus {
  PENDING    // виставлено на продаж, очікує покупця
  COMPLETED  // угода успішно виконана
  CANCELED   // продавець відкликав або угода скасована
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
}

enum PayoutMethod {
  USDT_TRC20
  USDT_ERC20
  PAYPAL
}

enum LegalActionStatus {
  PLAINTIFF_WON  // позивач переміг; штраф списаний з відповідача
  DEFENDANT_WON  // відповідач переміг; справу закрито без фінансових наслідків
  SETTLED        // мирова угода (для майбутнього розширення)
}

enum EnergySourceType {
  GRID             // стандартна міська мережа (тариф міста або EnergyContract)
  SOLAR_AUTONOMOUS // СЕС + акумулятори (мережа як резерв при нестачі)
  DIESEL_BACKUP    // дизельний генератор при відключеннях; мережа при нормальній роботі
}

enum CustomsStatus {
  PENDING   // на митниці
  CLEARED   // пропущено
  REJECTED  // відхилено
}

enum SubsidyType {
  AGRO_DEVELOPMENT   // Держпідтримка агросектору (аналог «Аграрного фонду»)
  GREEN_TRANSITION   // Компенсація за «зелене» обладнання (ЄБРР/USAID аналог)
  REGIONAL_STIMULUS  // Регіональні гранти (аналог «Великого будівництва»)
}

enum LicenseType {
  AGRO_PERMIT            // AGRO_FARM, FOOD_PROCESSING
  MANUFACTURING_LICENSE  // TEXTILE_FACTORY
  RETAIL_PERMIT          // RETAIL_STORE
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum MacroEventType {
  POWER_OUTAGE           // Аварійне відключення електроенергії
  LOGISTICS_BOTTLENECK   // Затримки на маршруті
  GRAIN_MARKET_BOOM      // Ціновий спалах на зернові
}

enum MacroEventStatus {
  ACTIVE
  EXPIRED
}

enum TechCode {
  LEAN_PRODUCTION     // Tier 1 — підвищує ефективність RP-генерації (+20%)
  GREEN_ENERGY        // Tier 1 — зменшує споживання ел/е всіх підприємств (×0.85)
  ADVANCED_LOGISTICS  // Tier 2 (потребує LEAN_PRODUCTION) — паливо -10% (×0.90)
  HIGH_TECH_AGRO      // Tier 2 (потребує LEAN_PRODUCTION) — якість аграрного вир-ва +1.5
}

enum LoanStatus {
  ACTIVE    // платежі вчасно
  OVERDUE   // прострочено 1–60 тиків
  DEFAULTED // прострочено > 60 тиків
  PAID_OFF  // погашено
}

enum DeliveryStatus {
  IN_TRANSIT  // вантаж у дорозі
  DELIVERED   // успішно доставлено та розміщено
  SPOILING    // прибуло, але склад переповнений — псування 10%/тік
  FAILED      // знищено повністю або скасовано
}

// Категорії для P&L-звітності.  Кожна операція в FinancialLog має рівно одну.
enum FinancialLogCategory {
  REVENUE_RETAIL        // виручка від роздрібних продажів (NPC)
  REVENUE_B2B           // виручка від B2B-ринку
  EXPENSE_SALARY        // брутто зарплата (без ЄСВ)
  EXPENSE_ESV           // ЄСВ роботодавця 22%
  EXPENSE_TAX           // ПДВ, ПнП, ПДФО, військовий збір
  EXPENSE_ENERGY        // електроенергія
  EXPENSE_LOGISTICS     // вартість перевезень
  EXPENSE_LEASE         // оренда землі / офісу
  EXPENSE_INTEREST      // відсотки за кредитами
  EXPENSE_MAINTENANCE   // технічне обслуговування
  EXPENSE_DEPRECIATION  // амортизація обладнання
  ADJUSTMENT            // коригування / коригувальні записи
  REVENUE_MA            // надходження від продажу бізнесу (M&A)
  EXPENSE_MA            // витрати на придбання бізнесу (M&A)
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLAYERS
// ═══════════════════════════════════════════════════════════════════════════════

model Player {
  id              String   @id @default(uuid())
  email           String   @unique
  username        String   @unique
  passwordHash    String
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  companyName     String   @default("Моя компанія")
  // Поточний залишок на рахунку (UAH)
  cashBalance     Decimal  @default(500000) @db.Decimal(18, 2)
  // Валютний рахунок (USD). Поповнюється через FX-обмін або експортний виторг.
  balanceUsd      Decimal  @default(0)      @db.Decimal(18, 4)
  // Чиста вартість: готівка + активи − борги. Перераховується щомісяця.
  netWorth        Decimal  @default(500000) @db.Decimal(18, 2)
  creditRating    Float    @default(7.0)   // 0–10
  reputationScore Float    @default(5.0)   // 0–10
  createdAt       DateTime @default(now())
  lastActiveAt    DateTime @default(now())
  // ── Banking & Overdraft (Step 19) ─────────────────────────────────────────
  // Ліміт овердрафту, встановлений банком (UAH). 0 = овердрафт недоступний.
  overdraftLimitUah         Decimal  @default(0) @db.Decimal(18, 2)
  // Поточна заборгованість за овердрафтом (UAH). Зростає з відсотками (36% р./р.)
  currentOverdraftUsageUah  Decimal  @default(0) @db.Decimal(18, 2)
  // ── Corporate Valuation (Step 18) ─────────────────────────────────────────
  // Поточна ринкова оцінка компанії (UAH); оновлюється calculateCompanyValuation()
  companyValuationUah  Decimal  @default(0)      @db.Decimal(22, 2)
  // True якщо компанія або окреме підприємство виставлені на продаж
  isListedForSale      Boolean  @default(false)
  // Мінімальна ціна продажу, встановлена продавцем (UAH)
  minimumSalePriceUah  Decimal  @default(0)      @db.Decimal(22, 2)
  // ── R&D state ──────────────────────────────────────────────────────────────
  // ID технології (Technology.id), яка зараз досліджується; null = дослідження не ведеться
  activeResearchTechId String?

  // ── Insolvency state ───────────────────────────────────────────────────────
  // Consecutive ticks with negative cashBalance (reset when positive)
  insolvencyTickCount  Int      @default(0)
  // True when balance has been negative for 7+ ticks — operations frozen
  isOperationsFrozen   Boolean  @default(false)
  // True after bankruptcy procedure is executed
  isBankrupt           Boolean  @default(false)
  bankruptcyStartedAt  DateTime?

  offices         Office[]
  landPlots       LandPlot[]
  enterprises     Enterprise[]
  employees       Employee[]
  marketOrders    MarketOrder[]
  transactions    FinancialTransaction[]
  playerInventory PlayerInventory[]
  taxRecords      TaxRecord[]
  energyBills     EnergyBill[]
  loans           Loan[]
  warehouses        Warehouse[]
  pendingDeliveries PendingDelivery[]
  financialLogs     FinancialLog[]
  licenses          License[]
  complianceRecord  ComplianceRecord?
  taxInspections    TaxInspection[]
  technologies      PlayerTechnology[]
  dailySnapshots    DailySnapshot[]
  productionLogs    ProductionLog[]
  autoContracts        AutoContract[]
  hrPolicy             HRAutomationPolicy?
  subsidyApplications  SubsidyApplication[]
  customsDeclarations  CustomsDeclaration[]
  energyContracts      EnergyContract[]
  securitySystems      SecuritySystem[]
  patents              Patent[]
  legalActionsAsPlaintiff LegalAction[] @relation("PlaintiffLegalActions")
  legalActionsAsDefendant LegalAction[] @relation("DefendantLegalActions")
  maDealAsBuyer           MaDeal[]      @relation("MaDealBuyer")
  maDealAsSeller          MaDeal[]      @relation("MaDealSeller")
  deposits                Deposit[]
  ownedTickers            StockTicker[]
  shareholdings           ShareholderRegistry[]
  stockOrders             StockOrderBook[] @relation("PlayerStockOrders")
  replenishRules          ReplenishRule[]
  withdrawalRequests      WithdrawalRequest[]
  supplyRoutes            SupplyRoute[]
  trainingSessions        TrainingSession[]
  syndicateLeadership     Syndicate?          @relation("SyndicateLeader")
  syndicateMembership     SyndicateMember?
  notifications           Notification[]

  @@index([username])
}

// ═══════════════════════════════════════════════════════════════════════════════
// GAME STATE
// ═══════════════════════════════════════════════════════════════════════════════

model GameTick {
  id          BigInt    @id @default(autoincrement())
  tickNumber  BigInt    @unique
  gameDay     BigInt
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?

  @@index([tickNumber])
}

// ═══════════════════════════════════════════════════════════════════════════════
// GEOGRAPHY
// ═══════════════════════════════════════════════════════════════════════════════

model City {
  id                String  @id @default(uuid())
  name              String  @unique
  nameUa            String
  region            String
  population        Int
  // Коефіцієнт зарплат відносно національного базового рівня (1.0 = середній по країні)
  wageCoefficient   Float   @default(1.0)
  // Місячна базова брутто-зарплата найнижчої кваліфікації у цьому місті (UAH).
  // Використовується для розрахунку настрою: якщо зарплата < базової → настрій падає.
  wageBaselineUah   Decimal @db.Decimal(10, 2)
  // Комерційний тариф на електроенергію (UAH/кВт·год), оцінка 2026
  energyTariffUah   Decimal @db.Decimal(8, 4)
  // Мультиплікатор попиту NPC відносно середнього по Україні
  demandCoefficient Float   @default(1.0)
  landPriceCoeff    Float   @default(1.0)
  latitude          Float
  longitude         Float

  landPlots   LandPlot[]
  offices     Office[]
  npcDemand   NpcDemand[]
  energyBills EnergyBill[]
  logisticsRoutesFrom LogisticsRoute[] @relation("RouteFromCity")
  logisticsRoutesTo   LogisticsRoute[] @relation("RouteToCity")
  warehouses          Warehouse[]

  @@index([name])
}

// ═══════════════════════════════════════════════════════════════════════════════
// LAND
// ═══════════════════════════════════════════════════════════════════════════════

model LandPlot {
  id                  String     @id @default(uuid())
  cityId              String
  playerId            String?
  cadastralNumber     String     @unique
  status              LandStatus @default(AVAILABLE)
  totalAreaM2         Float
  // Підтримується сервісом: sum(enterprise.footprintM2) ≤ totalAreaM2
  usedAreaM2          Float      @default(0)
  // Повна вартість ділянки (UAH) для купівлі
  purchasePriceUah    Decimal    @db.Decimal(14, 2)
  // Фіксована місячна орендна плата за всю ділянку (UAH)
  monthlyLeaseCostUah Decimal    @db.Decimal(12, 2)
  leaseStartDate      DateTime?
  leaseEndDate        DateTime?
  purchasedAt         DateTime?

  city        City         @relation(fields: [cityId], references: [id])
  player      Player?      @relation(fields: [playerId], references: [id])
  enterprises Enterprise[]

  @@index([cityId])
  @@index([playerId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// OFFICES — обов'язкова умова для будь-якого підприємства у місті
// ═══════════════════════════════════════════════════════════════════════════════

model Office {
  id                       String   @id @default(uuid())
  playerId                 String
  cityId                   String
  enterpriseId             String   @unique
  sizeM2                   Float    @default(50)
  // Споживання електроенергії офісом (кВт·год за ігровий день = 24 год)
  energyConsumptionKwhPerTick Float @default(30)
  // Місячна орендна плата за офісне приміщення, якщо не власне (UAH)
  monthlyRentUah           Decimal  @default(0) @db.Decimal(12, 2)
  isOperational            Boolean  @default(false)
  openedAt                 DateTime @default(now())

  player     Player     @relation(fields: [playerId], references: [id])
  city       City       @relation(fields: [cityId], references: [id])
  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])

  // Один активний офіс на гравця на місто
  @@unique([playerId, cityId])
  @@index([playerId])
  @@index([cityId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENTERPRISES
// Перевірка наявності офісу у місті — на рівні сервісу (GameEngineService).
// ═══════════════════════════════════════════════════════════════════════════════

model Enterprise {
  id               String         @id @default(uuid())
  playerId         String
  landPlotId       String
  type             EnterpriseType
  name             String
  // Площа забудови на земельній ділянці (м²)
  footprintM2      Float
  // Загальна та використана корисна площа будівлі (м²)
  totalFloorAreaM2 Float          @default(0)
  usedFloorAreaM2  Float          @default(0)
  isOperational    Boolean        @default(false)
  constructedAt    DateTime?
  // Постійне споживання: освітлення, ОВІК, охорона (кВт·год/тік незалежно від виробництва)
  basePowerKwhPerTick Float       @default(5)
  // ── Corporate finance flags ────────────────────────────────────────────────
  // True while this enterprise is pledged as loan collateral (cannot be sold/demolished)
  isCollateral     Boolean        @default(false)
  // True after bankruptcy seizure; enterprise becomes inoperable
  isSeized         Boolean        @default(false)
  // ── State regulation flags ─────────────────────────────────────────────────
  // True when frozen by a tax inspection; sales + production blocked
  isFrozenByInspection    Boolean  @default(false)
  inspectionFreezeUntilTick BigInt?
  // ── Legal freeze (Step 17) ────────────────────────────────────────────────
  // Судовий арест: B2B + логістика заблоковані до погашення боргу + суд.витрат
  isLegallyFrozen      Boolean  @default(false)
  legalFreezeReason    String?
  legalFreezeUntilTick BigInt?
  // ── Energy source (Step 16) ────────────────────────────────────────────────
  energySourceType    EnergySourceType @default(GRID)
  // СЕС: встановлена потужність (кВт)
  solarCapacityKw     Decimal  @default(0) @db.Decimal(10, 2)
  // Акумулятор: максимальна ємність та поточний заряд (кВт·год)
  batteryCapacityKwh  Decimal  @default(0) @db.Decimal(10, 2)
  currentBatteryKwh   Decimal  @default(0) @db.Decimal(10, 2)

  player               Player                @relation(fields: [playerId], references: [id])
  landPlot             LandPlot              @relation(fields: [landPlotId], references: [id])
  office               Office?
  workshops            Workshop[]
  employees            Employee[]
  inventory            EnterpriseInventory[]
  constructionProjects ConstructionProject[]
  warehouse            Warehouse?
  collateralLoans      Loan[]     @relation("CollateralEnterprise")
  licenses             License[]
  subsidyApplications  SubsidyApplication[]
  energyContracts      EnergyContract[]
  securitySystem       SecuritySystem?
  replenishRules       ReplenishRule[]
  supplyRoutesAsSource SupplyRoute[]        @relation("SupplyRouteSource")
  supplyRoutesAsTarget SupplyRoute[]        @relation("SupplyRouteTarget")

  @@index([playerId])
  @@index([landPlotId])
  @@index([type])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSHOPS / PRODUCTION LINES
// ═══════════════════════════════════════════════════════════════════════════════

model Workshop {
  id                  String  @id @default(uuid())
  enterpriseId        String
  name                String
  footprintM2         Float
  // Максимальна пропускна здатність за ігровий день (в одиницях виходу рецепту)
  maxCapacity         Float
  // Запланований об'єм виробництва цього тіку (≤ maxCapacity; встановлює гравець)
  currentVolume       Float   @default(0)
  isActive            Boolean @default(false)
  // Базове енергоспоживання виробничого простору (кВт·год/тік, незалежно від обладнання)
  basePowerKwhPerTick Float   @default(2)

  enterprise       Enterprise        @relation(fields: [enterpriseId], references: [id])
  equipment        Equipment[]
  productionOrders ProductionOrder[]

  @@index([enterpriseId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// EQUIPMENT
// ═══════════════════════════════════════════════════════════════════════════════

model Equipment {
  id                  String          @id @default(uuid())
  workshopId          String
  catalogProductId    String
  name                String
  status              EquipmentStatus @default(NEW)

  // Знос: 0.0 = ідеальний стан, 1.0 = повністю зруйноване
  wearAndTear         Float           @default(0.0)
  // Приріст зносу за ігровий день при 100% завантаженні (напр. 0.005 = 0.5%/день)
  wearRatePerTick     Float           @default(0.005)
  // Чи повністю виведене з ладу (wearAndTear ≥ 1.0 або несподіваний збій)
  isBroken            Boolean         @default(false)

  // Номінальне споживання потужності в кіловатах (кВт·год/день = кВт × 24 год)
  energyConsumptionKw Float
  // Мультиплікатор якості виходу у новому стані (0.0–1.0; преміум = 1.0)
  baseQualityModifier Float           @default(1.0)
  // Поточна ринкова/балансова вартість (UAH), зменшується зі зносом
  marketValueUah      Decimal         @db.Decimal(14, 2)
  // Вартість планового технічного обслуговування (UAH)
  maintenanceCostUah  Decimal         @db.Decimal(12, 2)
  purchasedAt         DateTime        @default(now())
  lastMaintenanceAt   DateTime        @default(now())

  workshop       Workshop @relation(fields: [workshopId], references: [id])
  catalogProduct Product  @relation(fields: [catalogProductId], references: [id])

  @@index([workshopId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMPLOYEES
// ═══════════════════════════════════════════════════════════════════════════════

model Employee {
  id            String     @id @default(uuid())
  playerId      String
  enterpriseId  String
  firstName     String
  lastName      String
  profession    Profession

  // Брутто місячна зарплата (UAH); роботодавець платить +22% ЄСВ зверху
  salaryUah        Decimal  @db.Decimal(10, 2)
  // Задоволеність: 0.0 = страйк/звільнення, 1.0 = повністю залучений
  mood             Float    @default(0.7)
  // Базовий рівень майстерності (встановлюється при наймі, зростає поступово)
  baseEfficiency   Float    @default(1.0)
  // Поточна ефективність після штрафу за настрій (0.0–1.0)
  efficiency       Float    @default(1.0)

  isOnStrike       Boolean  @default(false)
  strikeStartedTick BigInt?
  hiredAt          DateTime @default(now())
  lastPaidAt       DateTime?
  // Накопичена зарплата, ще не виплачена (поденне нарахування)
  accruedSalaryUah Decimal  @default(0) @db.Decimal(12, 2)

  // Рівень кваліфікації: 0 = без навчання, 5 = майстер
  qualificationLevel Int @default(0)

  player          Player            @relation(fields: [playerId],     references: [id])
  enterprise      Enterprise        @relation(fields: [enterpriseId], references: [id])
  trainingSessions TrainingSession[]

  @@index([playerId])
  @@index([enterpriseId])
  @@index([profession])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRODUCT CATALOG & RECIPES
// ═══════════════════════════════════════════════════════════════════════════════

model Product {
  id              String          @id @default(uuid())
  sku             String          @unique
  name            String
  nameUa          String
  category        ProductCategory
  unit            String          // "кг", "шт", "л", "кВт·год"
  baseWeightKg    Float           @default(0)
  baseVolumeLitre Float           @default(0)
  isEquipmentItem Boolean         @default(false)

  equipmentInstances  Equipment[]
  recipeOutputs       RecipeOutput[]
  recipeInputs        RecipeInput[]
  marketOrders        MarketOrder[]
  playerInventory     PlayerInventory[]
  enterpriseInventory EnterpriseInventory[]
  npcDemand           NpcDemand[]
  pendingDeliveries   PendingDelivery[]
  replenishRules      ReplenishRule[]
  supplyRoutes        SupplyRoute[]

  @@index([category])
  @@index([sku])
}

model Recipe {
  id               String         @id @default(uuid())
  name             String
  enterpriseType   EnterpriseType
  ticksToComplete  Int            @default(1)
  laborHoursPerUnit Float
  // Еталонна якість при ідеальних умовах (слугує верхньою межею)
  baseQuality      Float          @default(7.0)
  powerKwhPerUnit  Float

  inputs           RecipeInput[]
  outputs          RecipeOutput[]
  productionOrders ProductionOrder[]
}

model RecipeInput {
  id              String @id @default(uuid())
  recipeId        String
  productId       String
  quantityPerUnit Float  // одиниць входу на 1 одиницю виходу

  recipe  Recipe  @relation(fields: [recipeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([recipeId, productId])
}

model RecipeOutput {
  id              String @id @default(uuid())
  recipeId        String
  productId       String
  quantityPerUnit Float

  recipe  Recipe  @relation(fields: [recipeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([recipeId, productId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRODUCTION ORDERS
// ═══════════════════════════════════════════════════════════════════════════════

model ProductionOrder {
  id                String             @id @default(uuid())
  workshopId        String
  recipeId          String
  targetQuantity    Float
  completedQuantity Float              @default(0)
  outputQuality     Float?             // 0–10, обчислюється при завершенні
  status            ConstructionStatus @default(IN_PROGRESS)
  ticksRemaining    Int
  startedAt         DateTime           @default(now())
  completedAt       DateTime?

  workshop Workshop @relation(fields: [workshopId], references: [id])
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@index([workshopId, status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// INVENTORIES
// ═══════════════════════════════════════════════════════════════════════════════

model PlayerInventory {
  id         String   @id @default(uuid())
  playerId   String
  productId  String
  quantity   Float    @default(0)
  avgQuality Float    @default(0)
  updatedAt  DateTime @updatedAt

  player  Player  @relation(fields: [playerId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([playerId, productId])
}

model EnterpriseInventory {
  id           String   @id @default(uuid())
  enterpriseId String
  productId    String
  quantity     Float    @default(0)
  avgQuality   Float    @default(0)
  updatedAt    DateTime @updatedAt

  // Auto-sell: place SELL order when quantity > threshold
  autoSellThreshold Float    @default(0)
  autoSellPriceUah  Decimal? @db.Decimal(12, 4)

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([enterpriseId, productId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTO-REPLENISH RULES
// ═══════════════════════════════════════════════════════════════════════════════

model ReplenishRule {
  id               String    @id @default(uuid())
  playerId         String
  enterpriseId     String
  productId        String
  isActive         Boolean   @default(true)
  minStockTicks    Float     @default(3)
  maxPricePerUnit  Decimal   @db.Decimal(14, 4)
  lastTriggeredAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  player     Player     @relation(fields: [playerId],     references: [id])
  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  product    Product    @relation(fields: [productId],    references: [id])

  @@unique([enterpriseId, productId])
  @@index([playerId, isActive])
}

model WithdrawalRequest {
  id             String           @id @default(uuid())
  playerId       String
  amountPC       Float
  amountUSD      Float
  payoutMethod   PayoutMethod
  payoutAddress  String
  status         WithdrawalStatus @default(PENDING)
  adminNote      String?
  createdAt      DateTime         @default(now())
  processedAt    DateTime?

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, status])
  @@index([status, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// B2B MARKET
// ═══════════════════════════════════════════════════════════════════════════════

model MarketOrder {
  id             String            @id @default(uuid())
  playerId       String
  productId      String
  // Денормалізовано для швидкого пошуку без JOIN з Product (SKU або категорія)
  resourceType   String
  type           MarketOrderType
  status         MarketOrderStatus @default(OPEN)
  pricePerUnit   Decimal           @db.Decimal(12, 4)
  qualityMin     Float?            // для BUY-ордерів: мін. прийнятна якість
  quality        Float?            // для SELL-ордерів: якість виставленого товару (0–10)
  quantityTotal  Float
  quantityFilled Float             @default(0)
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  filledAt       DateTime?

  player      Player        @relation(fields: [playerId], references: [id])
  product     Product       @relation(fields: [productId], references: [id])
  asSellOrder MarketTrade[] @relation("SellOrder")
  asBuyOrder  MarketTrade[] @relation("BuyOrder")

  @@index([productId, type, status])
  @@index([resourceType, status])
  @@index([playerId])
  @@index([expiresAt])
}

model MarketTrade {
  id           String   @id @default(uuid())
  sellOrderId  String
  buyOrderId   String
  quantity     Float
  pricePerUnit Decimal  @db.Decimal(12, 4)
  quality      Float
  executedAt   DateTime @default(now())

  sellOrder MarketOrder @relation("SellOrder", fields: [sellOrderId], references: [id])
  buyOrder  MarketOrder @relation("BuyOrder", fields: [buyOrderId], references: [id])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENERGY BILLS
// ═══════════════════════════════════════════════════════════════════════════════

model EnergyBill {
  id             String   @id @default(uuid())
  playerId       String
  cityId         String
  tickNumber     BigInt
  consumptionKwh Float
  tariffUah      Decimal  @db.Decimal(8, 4)
  totalUah       Decimal  @db.Decimal(14, 2)
  isPaid         Boolean  @default(true)
  createdAt      DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])
  city   City   @relation(fields: [cityId], references: [id])

  @@index([playerId])
  @@index([tickNumber])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONSTRUCTION
// ═══════════════════════════════════════════════════════════════════════════════

model ConstructionProject {
  id             String             @id @default(uuid())
  enterpriseId   String
  name           String
  status         ConstructionStatus @default(PLANNED)
  totalCostUah   Decimal            @db.Decimal(14, 2)
  paidCostUah    Decimal            @default(0) @db.Decimal(14, 2)
  ticksRequired  Int
  ticksRemaining Int
  targetType     String             // "ENTERPRISE" | "WORKSHOP"
  targetId       String
  footprintM2    Float
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])

  @@index([enterpriseId, status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// FINANCIAL LEDGER
// ═══════════════════════════════════════════════════════════════════════════════

model FinancialTransaction {
  id            String          @id @default(uuid())
  playerId      String
  type          TransactionType
  amountUah     Decimal         @db.Decimal(18, 2) // > 0 = дохід, < 0 = витрата
  balanceBefore Decimal         @db.Decimal(18, 2)
  balanceAfter  Decimal         @db.Decimal(18, 2)
  description   String
  referenceId   String?
  createdAt     DateTime        @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, createdAt])
  @@index([type])
}

// ═══════════════════════════════════════════════════════════════════════════════
// NPC DEMAND
// ═══════════════════════════════════════════════════════════════════════════════

model NpcDemand {
  id              String  @id @default(uuid())
  cityId          String
  productId       String
  baseUnitsPerDay Float
  referencePrice  Decimal @db.Decimal(12, 4)
  priceElasticity Float   @default(-1.2)
  qualityWeight   Float   @default(0.6)

  city    City    @relation(fields: [cityId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([cityId, productId])
  @@index([cityId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// TAXATION
// ПДВ 20% | CIT 18% | ЄСВ 22% (роботодавець) | ПДФО 18% | Вій. збір 5%
// ═══════════════════════════════════════════════════════════════════════════════

model TaxRecord {
  id             String    @id @default(uuid())
  playerId       String
  periodStart    DateTime
  periodEnd      DateTime
  vatUah         Decimal   @db.Decimal(14, 2)
  citUah         Decimal   @db.Decimal(14, 2)
  esvUah         Decimal   @db.Decimal(14, 2)
  pdfoUah        Decimal   @db.Decimal(14, 2)
  militaryTaxUah Decimal   @db.Decimal(14, 2)
  totalUah       Decimal   @db.Decimal(14, 2)
  isPaid         Boolean   @default(false)
  dueAt          DateTime
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, isPaid])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CREDIT SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

model Loan {
  id                String     @id @default(uuid())
  playerId          String
  principalUah      Decimal    @db.Decimal(18, 2)
  remainingUah      Decimal    @db.Decimal(18, 2)
  annualInterestPct Float
  monthlyPaymentUah Decimal    @db.Decimal(14, 2)
  // Daily payment for commercial credit lines (monthlyPaymentUah / 30)
  dailyPaymentUah   Decimal    @default(0) @db.Decimal(14, 4)
  termMonths        Int
  paidMonths        Int        @default(0)
  missedPayments    Int        @default(0)
  status            LoanStatus @default(ACTIVE)
  issuedAt          DateTime   @default(now())
  nextPaymentTick   BigInt
  // 1 = daily commercial credit; 30 = standard monthly loan
  paymentFrequencyTicks Int    @default(30)
  fullyPaidAt       DateTime?
  // ── Collateral ─────────────────────────────────────────────────────────────
  collateralEnterpriseId String?
  collateralReleased     Boolean @default(false)

  player      Player      @relation(fields: [playerId], references: [id])
  collateral  Enterprise? @relation("CollateralEnterprise", fields: [collateralEnterpriseId], references: [id])
  payments    LoanPayment[]

  @@index([playerId, status])
  @@index([nextPaymentTick])
  @@index([collateralEnterpriseId])
}

model LoanPayment {
  id           String   @id @default(uuid())
  loanId       String
  totalUah     Decimal  @db.Decimal(14, 2)
  principalUah Decimal  @db.Decimal(14, 2)
  interestUah  Decimal  @db.Decimal(14, 2)
  wasOnTime    Boolean  @default(true)
  paidAt       DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id])

  @@index([loanId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// LOGISTICS — warehouse capacity, inter-city routes, pending deliveries
// ═══════════════════════════════════════════════════════════════════════════════

// Фізичний склад — прив'язаний до Enterprise типу WAREHOUSE або LOGISTICS_HUB.
// usedVolumeM3 підтримується LogisticsService; іншим сервісам не змінювати.
model Warehouse {
  id           String   @id @default(uuid())
  enterpriseId String   @unique
  // Денормалізовано для ефективного пошуку без JOIN
  cityId       String
  playerId     String
  maxVolumeM3  Float
  usedVolumeM3 Float    @default(0)
  isActive     Boolean  @default(true)

  enterprise     Enterprise       @relation(fields: [enterpriseId], references: [id])
  city           City             @relation(fields: [cityId],       references: [id])
  player         Player           @relation(fields: [playerId],     references: [id])
  fromDeliveries PendingDelivery[] @relation("DeliveryOrigin")
  toDeliveries   PendingDelivery[] @relation("DeliveryDestination")

  @@index([playerId, cityId])
  @@index([cityId])
}

// Попередньо розрахована матриця відстаней між містами України.
// Маршрут симетричний — зберігаємо лише один запис (from < to за алфавітом),
// LogisticsService шукає обидва напрямки через OR.
model LogisticsRoute {
  id          String @id @default(uuid())
  fromCityId  String
  toCityId    String
  distanceKm  Float
  // Ризик маршруту: 0.0 = ідеальні умови, 1.0 = непроїзно
  riskFactor  Float  @default(0.05)
  // Якість дороги впливає на середню швидкість: 1.0 = норма, 0.5 = вдвічі повільніше
  roadQuality Float  @default(1.0)

  fromCity City @relation("RouteFromCity", fields: [fromCityId], references: [id])
  toCity   City @relation("RouteToCity",   fields: [toCityId],   references: [id])

  @@unique([fromCityId, toCityId])
  @@index([fromCityId])
  @@index([toCityId])
}

// Вантаж у дорозі. Ресурси списані з джерела одразу при відправці;
// зараховуються на склад призначення при ticksRemaining = 0.
model PendingDelivery {
  id              String         @id @default(uuid())
  playerId        String
  fromWarehouseId String
  toWarehouseId   String
  productId       String
  // Кількість у поточному стані (зменшується при псуванні)
  quantity        Float
  quality         Float
  volumeM3        Float
  freightCostUah  Decimal        @db.Decimal(14, 2)
  ticksTotal      Int
  ticksRemaining  Int
  status          DeliveryStatus @default(IN_TRANSIT)
  // Накопичений відсоток втрат (тільки інформаційне поле)
  spoiledPct      Float          @default(0)
  dispatchedAt    DateTime       @default(now())
  arrivedAt       DateTime?

  player        Player    @relation(fields: [playerId],        references: [id])
  fromWarehouse Warehouse @relation("DeliveryOrigin",      fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("DeliveryDestination", fields: [toWarehouseId],   references: [id])
  product       Product   @relation(fields: [productId],       references: [id])

  @@index([playerId])
  @@index([status, ticksRemaining])
  @@index([toWarehouseId, status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CORPORATE FINANCE — structured P&L audit trail
// ═══════════════════════════════════════════════════════════════════════════════

// Категоризований журнал фінансових операцій для генерації P&L-звітів.
// Паралельно до FinancialTransaction (загальний лежер).
// FinanceService пише сюди; інші сервіси за потреби можуть теж.
model FinancialLog {
  id          String               @id @default(uuid())
  playerId    String
  category    FinancialLogCategory
  // > 0 = дохід, < 0 = витрата (у гривнях, без ПДВ)
  amountUah   Decimal              @db.Decimal(18, 2)
  description String
  referenceId String?              // loanId / enterpriseId / orderId etc.
  tickNumber  BigInt
  recordedAt  DateTime             @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, category, tickNumber])
  @@index([playerId, tickNumber])
  @@index([tickNumber])
}

// ═══════════════════════════════════════════════════════════════════════════════
// STATE REGULATION — licenses, compliance, tax inspections, macro events
// ═══════════════════════════════════════════════════════════════════════════════

// Державна ліцензія / дозвіл на діяльність підприємства.
// Термін дії: 30 тиків (30 ігрових днів).
model License {
  id            String        @id @default(uuid())
  playerId      String
  enterpriseId  String
  type          LicenseType
  status        LicenseStatus @default(ACTIVE)
  issuedAtTick  BigInt
  expiresAtTick BigInt
  revokedAtTick BigInt?
  feePaidUah    Decimal       @db.Decimal(14, 2)
  issuedAt      DateTime      @default(now())

  player     Player     @relation(fields: [playerId],     references: [id])
  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])

  @@index([playerId, status])
  @@index([enterpriseId, type, status])
  @@index([expiresAtTick])
}

// Рейтинг відповідності гравця регуляторним вимогам (0.0–1.0).
// Один запис на гравця; оновлюється щотіково в processRegulationTick().
model ComplianceRecord {
  id                    String   @id @default(uuid())
  playerId              String   @unique
  score                 Float    @default(1.0)   // 0.0 = повна невідповідність, 1.0 = ідеал
  lastAuditTick         BigInt?
  consecutiveViolations Int      @default(0)     // тики поспіль з порушеннями
  updatedAt             DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])

  @@index([score])
}

// Акт перевірки ДПС: зафіксовані порушення та нараховані штрафи.
model TaxInspection {
  id              String   @id @default(uuid())
  playerId        String
  triggerReason   String
  // Сума виявленого ухилення (неоплачені податки + незадекларована зарплата)
  evadedAmountUah Decimal  @db.Decimal(18, 2)
  // Штраф = evadedAmount × 2 (200%)
  fineAmountUah   Decimal  @db.Decimal(18, 2)
  isPaid          Boolean  @default(false)
  paidAtTick      BigInt?
  conductedAtTick BigInt
  // Перелік заморожених підприємств (JSON-масив enterpriseId)
  frozenEnterpriseIds String   @default("[]")
  createdAt       DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, isPaid])
  @@index([conductedAtTick])
}

// Активна макроекономічна подія, що впливає на всіх або на конкретне місто / маршрут.
model MacroEvent {
  id           String          @id @default(uuid())
  type         MacroEventType
  status       MacroEventStatus @default(ACTIVE)
  // Для POWER_OUTAGE — постраждале місто
  affectedCityId   String?
  // Для LOGISTICS_BOTTLENECK — маршрут
  affectedFromCityId String?
  affectedToCityId   String?
  // Для GRAIN_MARKET_BOOM — коефіцієнт попиту (наприклад 1.35)
  demandMultiplier Float        @default(1.0)
  startTick    BigInt
  endTick      BigInt
  description  String

  @@index([status, endTick])
  @@index([type, status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// R&D — Technology Tree
// ═══════════════════════════════════════════════════════════════════════════════

// Глобальний каталог технологій (заповнюється сидом при старті).
// prerequisites — JSON-масив TechCode[], перевіряється в сервісі.
model Technology {
  id                    String   @id @default(uuid())
  code                  TechCode @unique
  name                  String
  description           String
  requiredResearchPoints Float
  tier                  Int
  prerequisites         String   @default("[]")

  players PlayerTechnology[]

  @@index([tier])
}

// Прогрес конкретного гравця по конкретній технології.
model PlayerTechnology {
  id                    String   @id @default(uuid())
  playerId              String
  technologyId          String
  currentProgressPoints Float    @default(0)
  isUnlocked            Boolean  @default(false)
  unlockedAtTick        BigInt?
  updatedAt             DateTime @updatedAt

  player     Player     @relation(fields: [playerId],     references: [id])
  technology Technology @relation(fields: [technologyId], references: [id])

  @@unique([playerId, technologyId])
  @@index([playerId, isUnlocked])
}

// ═══════════════════════════════════════════════════════════════════════════════
// BI ANALYTICS — pre-aggregated tables for dashboard queries
// ═══════════════════════════════════════════════════════════════════════════════

// Знімок фінансового стану гравця кожні TICKS_PER_SNAPSHOT тиків (≈1 тиждень).
// Слугує основним джерелом для getFinancialTimeSeries (breakdown = WEEK).
// Пише AnalyticsService.populateDailySnapshot().
model DailySnapshot {
  id                String  @id @default(uuid())
  playerId          String
  tickNumber        BigInt
  gameWeek          BigInt  // tickNumber ÷ TICKS_PER_SNAPSHOT (floor)

  // Balance sheet at snapshot moment
  cashBalance       Decimal @db.Decimal(18, 2)
  totalAssetsValue  Decimal @db.Decimal(18, 2)  // cash + equipment + owned land

  // P&L since previous snapshot
  revenueUah        Decimal @db.Decimal(18, 2)
  opexUah           Decimal @db.Decimal(18, 2)  // energy + salary + logistics
  taxPaidUah        Decimal @db.Decimal(18, 2)
  netProfitUah      Decimal @db.Decimal(18, 2)

  // Operational metrics
  averageWorkerMood  Float
  activeEnterprises  Int
  employeeCount      Int

  recordedAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@unique([playerId, tickNumber])
  @@index([playerId, gameWeek])
  @@index([tickNumber])
}

// Денормалізований журнал виробництва — один запис на Workshop×Tick.
// Пише AnalyticsService.recordProductionResults() після кожного processProduction().
// Слугує джерелом для LaborProductivity KPI та supply-chain аналітики.
model ProductionLog {
  id            String   @id @default(uuid())
  playerId      String
  enterpriseId  String
  workshopId    String
  recipeId      String
  tickNumber    BigInt
  unitsProduced Float
  avgQuality    Float
  recordedAt    DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, tickNumber])
  @@index([enterpriseId, tickNumber])
  @@index([tickNumber])
}

// ═══════════════════════════════════════════════════════════════════════════════
// QUALIFICATION (навчання працівників)
// ═══════════════════════════════════════════════════════════════════════════════

model TrainingSession {
  id             String   @id @default(uuid())
  employeeId     String
  playerId       String
  targetLevel    Int      // 1-5
  costUah        Decimal  @db.Decimal(12, 2)
  ticksRequired  Int
  ticksRemaining Int
  isCompleted    Boolean  @default(false)
  startedAt      DateTime @default(now())
  completedAt    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
  player   Player   @relation(fields: [playerId],   references: [id])

  @@index([playerId, isCompleted])
  @@index([employeeId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYNDICATE (гравецькі об'єднання)
// ═══════════════════════════════════════════════════════════════════════════════

enum SyndicateRole {
  LEADER
  OFFICER
  MEMBER
}

model Syndicate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  leaderId    String   @unique
  maxMembers  Int      @default(20)
  isPublic    Boolean  @default(true)
  treasury    Decimal  @default(0) @db.Decimal(18, 2)
  createdAt   DateTime @default(now())

  leader  Player            @relation("SyndicateLeader", fields: [leaderId], references: [id])
  members SyndicateMember[]

  @@index([isPublic])
}

model SyndicateMember {
  id          String        @id @default(uuid())
  syndicateId String
  playerId    String        @unique
  role        SyndicateRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  syndicate Syndicate @relation(fields: [syndicateId], references: [id])
  player    Player    @relation(fields: [playerId],    references: [id])

  @@index([syndicateId])
}

// Маршрут внутрішнього постачання: автоматичний трансфер товару між підприємствами гравця кожен тік.
model SupplyRoute {
  id                 String   @id @default(uuid())
  playerId           String
  sourceEnterpriseId String
  targetEnterpriseId String
  productId          String
  qtyPerTick         Float
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  player           Player     @relation(fields: [playerId],           references: [id])
  sourceEnterprise Enterprise @relation("SupplyRouteSource", fields: [sourceEnterpriseId], references: [id])
  targetEnterprise Enterprise @relation("SupplyRouteTarget", fields: [targetEnterpriseId], references: [id])
  product          Product    @relation(fields: [productId],          references: [id])

  @@index([playerId, isActive])
  @@index([sourceEnterpriseId])
  @@index([targetEnterpriseId])
}

model AutoContract {
  id               String   @id @default(uuid())
  buyerId          String
  sellerId         String?  // null = open market (any seller)
  resourceType     String   // matches MarketOrder.resourceType (SKU)
  maxPricePerUnit  Decimal  @db.Decimal(12, 4)
  minQuality       Float    @default(0)
  quantityPerTick  Float
  isActive         Boolean  @default(true)
  // Per-tick execution tracking (reset each tick)
  lastTickSpentUah Decimal  @default(0) @db.Decimal(14, 2)
  lastFilledQty    Float    @default(0)
  lastExecutedTick BigInt?
  totalSpentUah    Decimal  @default(0) @db.Decimal(18, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  buyer Player @relation(fields: [buyerId], references: [id])

  @@index([buyerId, isActive])
  @@index([resourceType, isActive])
}

model HRAutomationPolicy {
  id                 String   @id @default(uuid())
  playerId           String   @unique
  isActive           Boolean  @default(true)
  autoAdjustSalaries Boolean  @default(true)
  targetMood         Float    @default(0.85)
  maxSalaryCapUah    Decimal  @db.Decimal(12, 2)
  updatedAt          DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])
}

// ═══════════════════════════════════════════════════════════════════════════════
// FISCAL MACRO-BUDGET & STATE SUBSIDIES
// ═══════════════════════════════════════════════════════════════════════════════

// Singleton: один рядок на всю гру. id = FISCAL_BUDGET_SINGLETON_ID (фіксований рядок).
model StateBudget {
  id                      String    @id
  // Накопичені надходження з початку гри
  totalTaxRevenue         Decimal   @default(0) @db.Decimal(22, 2)
  accumulatedPdv          Decimal   @default(0) @db.Decimal(22, 2)   // ПДВ
  accumulatedOpexTaxes    Decimal   @default(0) @db.Decimal(22, 2)   // CIT + ЄСВ + ПДФО + Вій.збір
  // Видаткова частина
  allocatedSubsidiesTotal Decimal   @default(0) @db.Decimal(22, 2)
  // Митні надходження (мито + ПДВ при імпорті) — Step 15
  customsRevenueUah       Decimal   @default(0) @db.Decimal(22, 2)
  // Мітки останньої агрегації
  lastAggregatedTick      BigInt?
  lastAggregatedAt        DateTime?
  updatedAt               DateTime  @updatedAt
}

// Активна держпрограма підтримки бізнесу з лімітованим пулом коштів.
model SubsidyProgram {
  id                 String      @id @default(uuid())
  type               SubsidyType @unique
  isActive           Boolean     @default(true)
  availableFundsUah  Decimal     @db.Decimal(22, 2)
  subsidyPercentage  Float       // 0.25 = 25% cashback від базових капітальних витрат
  description        String
  // JSON-масив рядків EnterpriseType: [] = будь-який тип
  enterpriseTypes    String      @default("[]")
  minComplianceScore Float       @default(0.90)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  applications SubsidyApplication[]
}

// Запис поданої заявки (запобігає повторному отриманню субсидії для того ж підприємства).
model SubsidyApplication {
  id               String      @id @default(uuid())
  playerId         String
  enterpriseId     String
  programId        String
  subsidyType      SubsidyType
  baseCapexUah     Decimal     @db.Decimal(18, 2)
  subsidyAmountUah Decimal     @db.Decimal(14, 2)
  appliedAtTick    BigInt
  createdAt        DateTime    @default(now())

  player     Player         @relation(fields: [playerId],     references: [id])
  enterprise Enterprise     @relation(fields: [enterpriseId], references: [id])
  program    SubsidyProgram @relation(fields: [programId],    references: [id])

  @@unique([playerId, enterpriseId, subsidyType])
  @@index([playerId, subsidyType])
  @@index([enterpriseId])
  @@index([appliedAtTick])
}

// ═══════════════════════════════════════════════════════════════════════════════
// FOREIGN TRADE, FX MARKET & CUSTOMS — Step 15
// ═══════════════════════════════════════════════════════════════════════════════

// Singleton: поточний курс USD/UAH та накопичений торговельний баланс.
model FxRateSingleton {
  id                   String   @id   // fixed 'fx-rate-singleton'
  usdToUah             Decimal  @db.Decimal(10, 4)   // поточний міжбанківський курс
  baseRate             Decimal  @db.Decimal(10, 4)   // якірний курс (41.50)
  // Накопичений торговельний баланс з початку гри
  cumulativeExportUsd  Decimal  @default(0) @db.Decimal(22, 4)
  cumulativeImportUsd  Decimal  @default(0) @db.Decimal(22, 4)
  lastUpdatedTick      BigInt?
  updatedAt            DateTime @updatedAt
}

// Котирування ключових commodity на світовому ринку (USD/одиниця).
model GlobalMarketTicker {
  id               String   @id @default(uuid())
  commodity        String   @unique  // збігається з Product.sku або власний код
  priceUsd         Decimal  @db.Decimal(12, 4)
  previousPriceUsd Decimal  @db.Decimal(12, 4)
  baselineUsd      Decimal  @db.Decimal(12, 4)   // рівноважна ціна (mean-reversion)
  volatilityPct    Float    @default(0.02)         // σ цінового кроку за тік
  changePercent    Float    @default(0)
  updatedAtTick    BigInt?
  updatedAt        DateTime @updatedAt
}

// Митна декларація: відстежує кожне імпортне або експортне відправлення.
model CustomsDeclaration {
  id                   String        @id @default(uuid())
  playerId             String
  type                 CustomsType
  status               CustomsStatus @default(PENDING)
  resourceType         String        // SKU / commodity code
  quantity             Float
  // Вартість партії в USD (quantity × ticker price at creation)
  customsValueUsd      Decimal       @db.Decimal(18, 4)
  // Митний збір та ПДВ (UAH) — 0 поки вантаж заморожений
  dutyPaidUah          Decimal       @default(0) @db.Decimal(14, 2)
  vatPaidUah           Decimal       @default(0) @db.Decimal(14, 2)
  // Акумульована складська плата (500 UAH/тік при заморожуванні)
  storageFeeAccruedUah Decimal       @default(0) @db.Decimal(14, 2)
  fxRateAtCreation     Decimal       @db.Decimal(10, 4)
  // Для імпорту: місто призначення
  destinationCityId    String?
  // Тік появи на кордоні (скидається при сплаті мита заморожених декларацій)
  createdAtTick        BigInt
  clearedAtTick        BigInt?
  rejectionReason      String?
  createdAt            DateTime      @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, status])
  @@index([status, createdAtTick])
  @@index([createdAtTick])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENERGY MARKET — Step 16
// ═══════════════════════════════════════════════════════════════════════════════

// Прямий договір між великим промисловим підприємством та комерційним генератором.
// Дозволяє платити за фіксованим тарифом замість регіонального (економія на пікових тарифах).
model EnergyContract {
  id             String   @id @default(uuid())
  playerId       String
  enterpriseId   String
  // Фіксований тариф UAH/кВт·год (як правило нижче міського в 1.5–2×)
  fixedTariffUah Decimal  @db.Decimal(8, 4)
  // Максимальний обсяг за контрактом (кВт·год/тік); понад ліміт — по міському тарифу
  maxKwhPerTick  Float
  isActive       Boolean  @default(true)
  startsAtTick   BigInt
  expiresAtTick  BigInt?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player     Player     @relation(fields: [playerId],     references: [id])
  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])

  @@index([enterpriseId, isActive])
  @@index([playerId])
  @@index([expiresAtTick])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CORPORATE SECURITY, PATENTS & LEGAL ACTIONS — Step 17
// ═══════════════════════════════════════════════════════════════════════════════

// Система фізичної безпеки підприємства (охорона, відеоспостереження, контроль доступу).
// Впливає на Defense Score та знижує ризик штрафів при аудитах.
model SecuritySystem {
  id               String   @id @default(uuid())
  enterpriseId     String   @unique
  playerId         String
  // Рівень безпеки 1–5 (1 = мінімальний, 5 = банківський рівень)
  securityLevel    Int      @default(1)
  // Кількість активних охоронців (SECURITY_GUARD + SECURITY_OFFICER)
  guardCount       Int      @default(0)
  // Сукупна місячна вартість: ЗП охоронців + обладнання + ліцензії (UAH)
  monthlyUpkeepUah Decimal  @db.Decimal(12, 2)
  isActive         Boolean  @default(true)
  installedAtTick  BigInt
  updatedAt        DateTime @updatedAt

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  player     Player     @relation(fields: [playerId],     references: [id])

  @@index([playerId, isActive])
}

// Патент на досліджену технологію. Захищає власника від безоплатного копіювання
// конкурентами; надає право подати PatentLawsuit при порушенні.
model Patent {
  id               String   @id @default(uuid())
  playerId         String
  // TechCode як рядок — не FK, щоб зберегти гнучкість при розширенні TechCode
  technologyCode   String
  // Відсоток ліцензійного відрахування від розрахованої вигоди порушника
  licenseRoyaltyPct Float   @default(0.15)
  isActive         Boolean  @default(true)
  registeredAtTick BigInt
  createdAt        DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  // Один гравець — один патент на технологію
  @@unique([playerId, technologyCode])
  @@index([technologyCode, isActive])
  @@index([playerId, isActive])
}

// Запис судового процесу щодо порушення патентних прав.
// Розрахунок вигоди та штрафу фіксується в момент ухвалення рішення.
model LegalAction {
  id                   String            @id @default(uuid())
  plaintiffId          String
  defendantId          String
  technologyCode       String
  status               LegalActionStatus
  // Агрегована ефективність адвокатів кожної сторони на момент позову
  plaintiffLawyerScore Float
  defendantLawyerScore Float
  // Розрахована вигода відповідача від використання технології без ліцензії (UAH)
  benefitUah           Decimal  @db.Decimal(18, 2)
  // Штраф = benefitUah × 3.0 (лише при PLAINTIFF_WON)
  penaltyUah           Decimal  @default(0) @db.Decimal(18, 2)
  description          String
  resolvedAtTick       BigInt
  createdAt            DateTime @default(now())

  plaintiff Player @relation("PlaintiffLegalActions", fields: [plaintiffId], references: [id])
  defendant Player @relation("DefendantLegalActions", fields: [defendantId], references: [id])

  @@index([plaintiffId])
  @@index([defendantId])
  @@index([technologyCode])
  @@index([resolvedAtTick])
}

// ═══════════════════════════════════════════════════════════════════════════════
// M&A — CORPORATE ACQUISITIONS — Step 18
// ═══════════════════════════════════════════════════════════════════════════════

// Запис про операцію злиття/поглинання або продаж окремого підприємства.
// targetEnterpriseId = null → повний викуп компанії.
// targetEnterpriseId = id → продаж конкретного підприємства.
model MaDeal {
  id                   String       @id @default(uuid())
  buyerId              String?      // null поки угода PENDING (покупець ще невідомий)
  sellerId             String
  // null = продаж усієї компанії; non-null = продаж конкретного підприємства
  targetEnterpriseId   String?
  // Мінімальна ціна, встановлена продавцем; може бути змінена до виконання
  transactionAmountUah Decimal      @db.Decimal(22, 2)
  status               MaDealStatus @default(PENDING)
  listedAtTick         BigInt
  executedAtTick       BigInt?
  canceledAtTick       BigInt?
  notes                String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  buyer  Player? @relation("MaDealBuyer",  fields: [buyerId],  references: [id])
  seller Player  @relation("MaDealSeller", fields: [sellerId], references: [id])

  @@index([sellerId, status])
  @@index([buyerId,  status])
  @@index([status,   listedAtTick])
}

// ═══════════════════════════════════════════════════════════════════════════════
// BANKING — CORPORATE DEPOSITS & OVERDRAFT — Step 19
// ═══════════════════════════════════════════════════════════════════════════════

// Строковий корпоративний депозит.
// Кошти знімаються з рахунку при відкритті і повертаються з відсотками при погашенні.
// Ставка (annualYieldRate) фіксується на момент відкриття і не змінюється.
model Deposit {
  id              String          @id @default(uuid())
  playerId        String
  currency        DepositCurrency
  // Сума, що розміщується (без відсотків)
  principalAmount Decimal         @db.Decimal(18, 4)
  // Річна ставка у форматі 0.15 = 15%. Фіксується при відкритті.
  annualYieldRate Decimal         @db.Decimal(6,  4)
  startTick       BigInt
  durationTicks   BigInt          // кількість тіків (1 тік = 1 день)
  isMatured       Boolean         @default(false)
  // Заповнюється при погашенні: фактична фінальна сума (principal + interest)
  finalAmountPaid Decimal?        @db.Decimal(18, 4)
  maturedAtTick   BigInt?
  createdAt       DateTime        @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, isMatured])
  @@index([isMatured, startTick])
}

// ═══════════════════════════════════════════════════════════════════════════════
// STOCK EXCHANGE — IPO, ORDER BOOK, DIVIDENDS — Step 20
// ═══════════════════════════════════════════════════════════════════════════════

// Тікер публічної компанії на фондовій біржі UAeconomy.
// Один гравець — максимум один тікер.
model StockTicker {
  id                 String   @id @default(uuid())
  playerId           String   @unique          // засновник / емітент (не може мати два тікери)
  symbol             String   @unique          // напр. "UAGR", "UKR_MET"
  totalSharesIssued  BigInt                    // загальна кількість акцій в обігу
  // Акції у вільному обігу (treasury / float, не розподілені між гравцями).
  // Зменшується при купівлі float-ордерів; збільшується при відкликанні.
  freeFloatShares    BigInt   @default(0)
  lastTradedPriceUah Decimal  @db.Decimal(18, 4)
  // Фундаментальна оцінка (оновлюється з Player.companyValuationUah щотіку)
  targetValuationUah Decimal  @db.Decimal(22, 2)
  // Ринкова капіталізація = totalSharesIssued × lastTradedPriceUah
  marketCapUah       Decimal  @db.Decimal(22, 2)
  isActive           Boolean  @default(true)
  ipoExecutedAtTick  BigInt?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  player       Player                @relation(fields: [playerId],  references: [id])
  shareholders ShareholderRegistry[]
  orderBook    StockOrderBook[]

  @@index([isActive])
  @@index([symbol])
}

// Реєстр акціонерів: скільки акцій якого тікера має кожен гравець.
model ShareholderRegistry {
  id          String @id @default(uuid())
  playerId    String
  tickerId    String
  sharesCount BigInt

  player Player      @relation(fields: [playerId], references: [id])
  ticker StockTicker @relation(fields: [tickerId], references: [id])

  @@unique([playerId, tickerId])
  @@index([tickerId])
  @@index([playerId])
}

// Активна книга ордерів для торгівлі акціями.
// placedByPlayerId = null означає ордер від treasury/float компанії (IPO-продаж або NPC).
model StockOrderBook {
  id               String           @id @default(uuid())
  tickerId         String
  type             StockOrderType
  placedByPlayerId String?          // null = treasury/float ордер (IPO або NPC)
  pricePerShareUah Decimal          @db.Decimal(18, 4)
  quantity         BigInt
  filledQuantity   BigInt           @default(0)
  status           StockOrderStatus @default(OPEN)
  createdAtTick    BigInt
  filledAtTick     BigInt?
  cancelledAtTick  BigInt?

  ticker         StockTicker @relation(fields: [tickerId],          references: [id])
  placedByPlayer Player?     @relation("PlayerStockOrders", fields: [placedByPlayerId], references: [id])

  @@index([tickerId, status, type])
  @@index([placedByPlayerId, status])
  @@index([createdAtTick])
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS (ігрові сповіщення гравця)
// ═══════════════════════════════════════════════════════════════════════════════

model Notification {
  id        String   @id @default(uuid())
  playerId  String
  type      String   // MARKET_FILLED | CONSTRUCTION_DONE | SALARY_PAID | LOAN_OVERDUE | EQUIPMENT_BROKEN | BANKRUPTCY_WARN
  title     String
  body      String
  entityId  String?  // orderId / enterpriseId / etc.
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, isRead])
  @@index([playerId, createdAt(sort: Desc)])
}
